# Browser GraphQL URL. In local development this stays same-origin and Vite
# proxies it to GRAPHQL_PROXY_TARGET.
REACT_APP_GRAPHQL_SERVER_URL=/graphql

# Local Vite proxy target and default codegen schema source.
GRAPHQL_PROXY_TARGET=https://demo-rpg.dev.revisium.io/graphql

# Optional override used only by codegen.ts when the proxy target is not the
# schema source (e.g. behind VPN).
# GRAPHQL_SCHEMA_URL=https://demo-rpg.dev.revisium.io/graphql

# Optional absolute server-side runtime URL. Production SSR pods normally set
# this at runtime; local dev falls back to GRAPHQL_PROXY_TARGET.
# GRAPHQL_SERVER_URL=https://demo-rpg.dev.revisium.io/graphql

# Dev server port (react-router dev / vite).
REACT_APP_PORT=5173
