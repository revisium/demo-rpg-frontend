# Federated GraphQL router URL (Apollo Router supergraph endpoint).
REACT_APP_GRAPHQL_SERVER_URL=https://demo-rpg-router.dev.revisium.io/graphql

# Optional override used only by codegen.ts when the runtime URL is not
# reachable from the workstation (e.g. behind VPN).
# REACT_APP_GRAPHQL_SCHEMA_URL=https://demo-rpg-router.dev.revisium.io/graphql

# Dev server port (react-router dev / vite).
REACT_APP_PORT=5173
